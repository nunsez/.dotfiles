{
  "telemetry.telemetryLevel": "off",
  "chat.agent.enabled": false,
  "chat.mcp.access": "none",
  "moonbit.ai.telemetry": "off",

  "terminal.integrated.defaultProfile.linux": "fish",
  "terminal.integrated.defaultProfile.osx": "fish",
  "terminal.integrated.fontSize": 18,
  "terminal.integrated.fontLigatures.enabled": false,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.initialHint": false,
  "terminal.integrated.enableVisualBell": false,

  "accessibility.signals.terminalBell": {
    "sound": "off",
    "announcement": "auto",
  },

  "editor.fontSize": 16,
  "editor.fontFamily": "JuliaMono, Monaco, Hack, Consolas, 'Droid Sans Mono', monospace",
  "editor.fontWeight": "300",
  "editor.fontLigatures": false,
  "editor.scrollbar.horizontalScrollbarSize": 16,
  "editor.scrollbar.verticalScrollbarSize": 16,
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file", // modifications
  "editor.defaultFormatter": "EditorConfig.EditorConfig",
  "editor.unicodeHighlight.nonBasicASCII": false,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.inlayHints.enabled": "on",
  "editor.guides.indentation": true,
  "editor.lineNumbers": "on",
  "editor.glyphMargin": true,
  "editor.cursorStyle": "line",
  "editor.minimap.enabled": true,
  "editor.minimap.maxColumn": 60,
  "editor.minimap.scale": 2,
  "editor.minimap.renderCharacters": false,
  "editor.showDeprecated": true,
  "editor.comments.insertSpace": true,
  "editor.renderWhitespace": "trailing",
  "editor.detectIndentation": true,
  "editor.insertSpaces": true,
  "editor.suggestSelection": "recentlyUsedByPrefix",
  "editor.acceptSuggestionOnEnter": "off",
  "editor.suggest.showDeprecated": false,
  "editor.suggest.showIcons": false,
  // Disable brackets highlight
  "editor.language.colorizedBracketPairs": [
    // ["[", "]"],
    // ["(", ")"],
    // ["{", "}"],
  ],
  "editor.largeFileOptimizations": true,

  "editor.semanticTokenColorCustomizations": {
    "rules": {
      "parameter.label:dart": { "foreground": "#d7dae0" },
      "property:dart": { "foreground": "#d7dae0" },
      // "annotation:dart": { "foreground": "#56b6c2" },
      "annotation:dart": { "foreground": "#d7dae0" },
      // "variable:dart": { "foreground": "#d7dae0" },
      "variable:dart": { "foreground": "#d19a66" },
      "enumMember": "#98c379"
    },
  },

  "editor.tokenColorCustomizations": {
    // "keywords": "#c678dd",
    "variables": "#d7dae0",
    "functions": "#61afef",
    "strings": "#98c379",
    // "comments": "#7f848e",
    // "types": "#e5c07b",
    // "numbers": "#d19a66",

    // Minimal
    "keywords": "#d7dae0",
    "comments": "#c678dd",
    "numbers": "#98c379",
    "types": "#d7dae0",

    "textMateRules": [
      { "scope": "variable.parameter", "settings": { "fontStyle": "" } },
      { "scope": "comment", "settings": { "fontStyle": "" } },
      { "scope": "keyword", "settings": { "foreground": "#d7dae0" } },
      { "scope": "string.regexp", "settings": { "foreground": "#98c379" } },
      // { "scope": "constant.numeric", "settings": { "foreground": "#98c379" } },

      // Minimal
      { "scope": "entity.name.type.module", "settings": { "foreground": "#d7dae0" } },
      { "scope": "keyword.operator.arithmetic", "settings": { "foreground": "#d7dae0" } },
      { "scope": "keyword.operator.assignment", "settings": { "foreground": "#d7dae0" } },
      { "scope": "keyword.operator.comparison", "settings": { "foreground": "#d7dae0" } },
      { "scope": "keyword.operator.logical", "settings": { "foreground": "#d7dae0" } },
      { "scope": "keyword.operator.new", "settings": { "foreground": "#d7dae0" } },
      { "scope": "constant.character.escape", "settings": { "foreground": "#d19a66" } },
      { "scope": "constant.language", "settings": { "foreground": "#98c379" } },
      { "scope": "variable.language", "settings": { "foreground": "#d7dae0" } },
      { "scope": "punctuation.section.embedded", "settings": { "foreground": "#7f848e" } },
      { "scope": "keyword.other.special-method", "settings": { "foreground": "#d7dae0" } },
      { "scope": "comment.unused", "settings": { "foreground": "#7f848e" } },
      // { "scope": "entity.name.type.class", "settings": { "foreground": "#d7dae0" } },
      // { "scope": "constant.other.symbol", "settings": { "foreground": "#d19a66" } },

      // Elixir
      { "scope": "variable.other.readwrite.elixir", "settings": { "foreground": "#d7dae0" } },
      { "scope": "constant.language.symbol.elixir", "settings": { "foreground": "#d19a66" } },
      // { "scope": "variable.other.constant.elixir", "settings": { "foreground": "#56b6c2" } },
      { "scope": "variable.other.constant.elixir", "settings": { "foreground": "#d7dae0" } },
      { "scope": "entity.name.function.typespec.elixir", "settings": { "foreground": "#d7dae0" } },
      { "scope": "entity.name.function.call.local.elixir", "settings": { "foreground": "#61afef" } },
      { "scope": "constant.language.symbol.double-quoted.elixir", "settings": { "foreground": "#d19a66" } },

      // Dart
      { "scope": "entity.name.type.class", "settings": { "foreground": "#d7dae0" } },
      { "scope": "variable.parameter", "settings": { "foreground": "#d19a66" } },
    ],
  },

  "files.autoSave": "onFocusChange",
  "files.eol": "auto",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,

  "workbench.colorTheme": "One Dark Pro Darker",
  "workbench.tips.enabled": false,
  "workbench.tree.indent": 20,
  "workbench.tree.renderIndentGuides": "always",
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 35,
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.editor.focusRecentEditorAfterClose": false,
  "workbench.editor.showTabs": "multiple",
  "workbench.editor.tabSizing": "fit",
  "workbench.editor.wrapTabs": true,
  "workbench.layoutControl.enabled": false,
  "workbench.secondarySideBar.defaultVisibility": "hidden",

  "workbench.colorCustomizations": {
    "editorCursor.foreground": "#ffcc00",
    "editorBracketHighlight.foreground1": "#9cdcfe",
    "editorBracketHighlight.foreground2": "#e79557",
    "editorBracketHighlight.foreground3": "#e894c9",
    "editorBracketHighlight.foreground4": "#f1fa8c",
    "editorBracketHighlight.foreground5": "#f7768e",
    "editorBracketHighlight.foreground6": "#ecc53d",
    "editorBracketHighlight.unexpectedBracket.foreground": "#ff3333",
  },

  "[elixir]": {
    "editor.rulers": [119],
    "editor.tabSize": 2,
    "editor.defaultFormatter": "JakeBecker.elixir-ls",
  },

  "[ruby]": {
    "editor.rulers": [119],
    "editor.tabSize": 2,
    "files.trimTrailingWhitespace": true,
    "files.trimFinalNewlines": true,
    "editor.semanticHighlighting.enabled": true,
  },

  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.rulers": [92],
  },

  "[javascript]": {
    "editor.rulers": [119],
  },

  "[dart]": {
    "editor.formatOnSave": true,
    "editor.formatOnType": false,
    "editor.rulers": [80],
    "editor.selectionHighlight": false,
    "editor.tabCompletion": "onlySnippets",
    "editor.wordBasedSuggestions": "off",
  },

  "[slim]": {
    "editor.rulers": [179],
    "editor.tabSize": 2,
  },

  "[markdown]": {
    "editor.wordWrap": "off",
  },

  "[makefile]": {
    "editor.insertSpaces": false,
  },

  "[json]": {
    "editor.quickSuggestions": {
      "strings": true,
    },
    "editor.suggest.insertMode": "replace",
  },

  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml",
  },

  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features",
  },

  "files.associations": {
    "*.exs": "elixir",
    "*.env": "shellscript",
  },

  "debug.console.fontSize": 16,
  "debug.console.acceptSuggestionOnEnter": "on",

  "diffEditor.codeLens": true,
  "diffEditor.ignoreTrimWhitespace": true,

  "explorer.confirmDelete": false,

  "git.openRepositoryInParentFolders": "never",

  "markdown.preview.fontSize": 16,

  "window.commandCenter": false,
  "window.menuBarVisibility": "toggle",
  "window.restoreFullscreen": true,
  "window.zoomLevel": 0.8,

  "search.collapseResults": "auto",

  "security.workspace.trust.untrustedFiles": "open",

  "explorer.confirmDragAndDrop": false,

  "remote.SSH.connectTimeout": 60,
  "remote.SSH.useLocalServer": false,
  "remote.SSH.enableDynamicForwarding": false,
  "remote.SSH.remotePlatform": {
    "macbook": "macOS",
  },
  // "remote.SSH.useExecServer": true,

  // Plugin settings

  "gitlens.codeLens.enabled": false,
  "elixirLS.suggestSpecs": false,
  "rust-analyzer.check.command": "clippy",

  "rubyLsp.enabledFeatures": {
    "inlayHint": false,
    "codeLens": false,
  },

  "rubyLsp.featureFlags": {
    "fullTestDiscovery": false,
    "launcher": true,
    "tapiocaAddon": false,
  },

  "rust-analyzer.inlayHints.parameterHints.enable": false,
  "rust-analyzer.inlayHints.typeHints.enable": false,
  "rust-analyzer.inlayHints.chainingHints.enable": false,
  "rust-analyzer.lens.implementations.enable": false,

  "security.allowedUNCHosts": ["wsl.localhost"],

  "kilo-code.allowedCommands": ["git log", "git diff", "git show"],
  "kilo-code.deniedCommands": [],
  "terminal.integrated.commandsToSkipShell": [
    "kilo-code.new.agentManagerOpen",
    "kilo-code.new.agentManager.showTerminal"
  ]
}
